# Supabase (Team Inbox database)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Product Database (Trade Show Portal Supabase - for /sku: product search)
NEXT_PUBLIC_PRODUCT_SUPABASE_URL=your_product_supabase_url
NEXT_PUBLIC_PRODUCT_SUPABASE_ANON_KEY=your_product_supabase_anon_key

# Product Catalog URL (for product links)
NEXT_PUBLIC_PRODUCT_CATALOG_URL=http://localhost:3002

# Google OAuth (for Gmail API)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
